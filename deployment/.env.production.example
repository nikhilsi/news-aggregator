# ClearNews Production Environment
# Copy to .env.production and fill in values:
#   cp .env.production.example .env.production

# JWT signing key — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME

# Optional: API keys for premium sources (not needed for RSS-only setup)
# WORLD_NEWS_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=
