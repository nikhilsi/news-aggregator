# JWT signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Database
DATABASE_URL=sqlite:///./news_aggregator.db

# Cache TTL (minutes)
CACHE_TTL_MINUTES=15

# Logging format: "json" (production) or "text" (local dev)
LOG_FORMAT=text

# WorldNewsAPI — https://worldnewsapi.com (Free tier, 500 req/day)
WORLD_NEWS_API_KEY=

# Alpha Vantage — https://www.alphavantage.co (Premium)
ALPHA_VANTAGE_API_KEY=

# Financial Modeling Prep — https://financialmodelingprep.com (Premium)
FMP_API_KEY=
